{
  "name": "dingtalk-robot-notifier",
  "version": "1.0.0",
  "description": "钉钉群消息推送机器人",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "cd client && npm start",
    "dev:server": "cd server && npm run dev",
    "build": "cd client && npm run build"
  },
  "dependencies": {
    "concurrently": "^7.6.0"
  }
}